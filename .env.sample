# Required secrets.
# HMAC shared secret for /webhooks/github. Must match the GitHub webhook secret.
GITHUB_WEBHOOK_SECRET=

# Personal access token used by the GitHub MCP server, gh CLI fallback, and AI
# backend subprocesses. Use repo scope; add workflow if agents touch CI.
GITHUB_TOKEN=

# Optional env-driven AI credentials injected into ephemeral runner containers.
# Set at least one credential for each backend you enable.
CLAUDE_CODE_OAUTH_TOKEN=
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=
OPENAI_API_KEY=
CODEX_ACCESS_TOKEN=

# Runner image and basic container policy. The daemon launches fresh runner
# containers through the Docker socket mounted in docker-compose.yaml.
AGENTS_RUNNER_IMAGE=ghcr.io/eloylp/agents-runner:latest
AGENTS_RUNNER_CPUS=
AGENTS_RUNNER_MEMORY=
AGENTS_RUNNER_PIDS_LIMIT=
AGENTS_RUNNER_TIMEOUT_SECONDS=
AGENTS_RUNNER_NETWORK_MODE=bridge
AGENTS_RUNNER_FILESYSTEM=workspace-tmp

# Optional daemon runtime overrides. These values match the current built-in
# defaults. Empty values are ignored, so YAML/SQLite startup config values can
# still remain authoritative when you do not want an env override.

AGENTS_LOG_LEVEL=info
AGENTS_LOG_FORMAT=text

AGENTS_HTTP_LISTEN_ADDR=:8080
AGENTS_HTTP_STATUS_PATH=/status
AGENTS_HTTP_WEBHOOK_PATH=/webhooks/github
AGENTS_HTTP_READ_TIMEOUT_SECONDS=15
AGENTS_HTTP_WRITE_TIMEOUT_SECONDS=15
AGENTS_HTTP_IDLE_TIMEOUT_SECONDS=60
AGENTS_HTTP_MAX_BODY_BYTES=1048576
AGENTS_HTTP_DELIVERY_TTL_SECONDS=3600
AGENTS_HTTP_SHUTDOWN_TIMEOUT_SECONDS=15

AGENTS_PROCESSOR_EVENT_QUEUE_BUFFER=256
AGENTS_PROCESSOR_MAX_CONCURRENT_AGENTS=4

AGENTS_DISPATCH_MAX_DEPTH=3
AGENTS_DISPATCH_MAX_FANOUT=4
AGENTS_DISPATCH_DEDUP_WINDOW_SECONDS=300

AGENTS_PROXY_ENABLED=false
AGENTS_PROXY_PATH=/v1/messages
AGENTS_PROXY_UPSTREAM_URL=
AGENTS_PROXY_UPSTREAM_MODEL=
AGENTS_PROXY_UPSTREAM_API_KEY_ENV=
AGENTS_PROXY_UPSTREAM_TIMEOUT_SECONDS=120
